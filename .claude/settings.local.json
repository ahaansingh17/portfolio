      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/resume)",
      "Bash(curl -s -o /tmp/served-resume.pdf -w \"%{http_code}, %{size_download} bytes\" http://localhost:3000/resume.pdf)",
      "Bash(git init *)",
      "Bash(git add *)"
    ]
  }
}
